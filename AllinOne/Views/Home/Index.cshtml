<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Granto</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Tajawal:wght@300;400;500;700;800;900&family=Cairo:wght@300;400;600;700;900&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" />

</head>
<body>

    <!-- ═══ NAVBAR ═══ -->
    <nav id="navbar">
        <a class="nav-logo" href="#">
            <div class="logo-icon"><i class="fas fa-graduation-cap"></i></div>
            <span>Granto</span>
        </a>

        <ul class="nav-links" id="navLinks">
            <li><a href="#">الرئيسية</a></li>
            <li><a href="#scholarships">المنح المتاحة</a></li>
            <li><a href="#how-it-works">كيف تعمل؟</a></li>
            <li><a href="#testimonials">آراء الطلاب</a></li>
            <li><a href="#">الاستشارات</a></li>
            <li><a href="#">لوحه التحكم</a></li>
            <li><a href="@Url.Action("Index", "CommunityChat", new { id = 2 })">المجتمع</a></li>

        </ul>

        <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
            <!-- Login / Register Right -->
            <ul class="navbar-nav">
                @if (User.Identity != null && User.Identity.IsAuthenticated)
                {
                    <li class="nav-item">
                        <span class="nav-link">مرحبًا @User.Identity.Name</span>
                    </li>

                    @* لو الادمن يظهر له Dashboard *@
                    @if (User.IsInRole("Admin"))
                    {
                        <li class="nav-item">
                            <a class="nav-link text-success" asp-controller="Admin" asp-action="Dashboard">لوحة التحكم</a>
                        </li>
                    }

                    <li class="nav-item">
                        <a class="nav-link text-danger" asp-controller="Account" asp-action="Logout">تسجيل الخروج</a>
                    </li>
                }
                else
                {
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Account" asp-action="Login">تسجيل الدخول</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link text-primary" asp-controller="Account" asp-action="Register">إنشاء حساب</a>
                    </li>
                }
        </div>
        <div class="hamburger" id="hamburger">
            <span></span><span></span><span></span>
        </div>
    </nav>

    <!-- ═══ HERO ═══ -->
    <section id="hero">
        <div class="hero-bg-circles">
            <span></span><span></span><span></span>
        </div>
        <div class="hero-inner">
            <div class="hero-text">
                <div class="hero-badge"><i class="fas fa-star"></i> المنصة الأولى للمنح الدراسية بالعربي</div>
                <h1 class="hero-title">اكتشف المنحة الدراسية <span>المناسبة</span> لك</h1>
                <p class="hero-sub">تصفح مئات المنح الدراسية حول العالم، تحدث مع خبراء حاصلين عليها، وانضم إلى مجتمع الطلاب العرب في منحتك المفضلة.</p>
                <div class="hero-cta">
                    <a class="btn-hero-primary" href="#scholarships"><i class="fas fa-search"></i> تصفح المنح الآن</a>
                    <a class="btn-hero-outline" href="#how-it-works"><i class="fas fa-play-circle"></i> كيف تعمل المنصة؟</a>
                </div>
                <div class="hero-stats">
                    <div class="stat">
                        <div class="stat-num">+500</div>
                        <div class="stat-label">منحة متاحة</div>
                    </div>
                    <div class="stat">
                        <div class="stat-num">+12K</div>
                        <div class="stat-label">طالب مسجّل</div>
                    </div>
                    <div class="stat">
                        <div class="stat-num">80+</div>
                        <div class="stat-label">دولة حول العالم</div>
                    </div>
                    <div class="stat">
                        <div class="stat-num">+300</div>
                        <div class="stat-label">خبير ومستشار</div>
                    </div>
                </div>
            </div>

            <div class="hero-visual">
                <div class="hero-illustration">
                    <div class="illus-card">
                        <div class="illus-icon gold"><i class="fas fa-award"></i></div>
                        <div class="illus-text">
                            <strong>منحة فولبرايت الأمريكية</strong>
                            <span>الولايات المتحدة الأمريكية</span>
                            <span class="illus-badge badge-funded">تمويل كامل</span>
                        </div>
                    </div>
                    <div class="illus-card">
                        <div class="illus-icon teal"><i class="fas fa-university"></i></div>
                        <div class="illus-text">
                            <strong>منحة DAAD الألمانية</strong>
                            <span>ألمانيا — دراسات عليا</span>
                            <span class="illus-badge badge-new">جديدة</span>
                        </div>
                    </div>
                    <div class="illus-card">
                        <div class="illus-icon blue"><i class="fas fa-globe"></i></div>
                        <div class="illus-text">
                            <strong>منح جامعة كيمبريدج</strong>
                            <span>المملكة المتحدة</span>
                            <span class="illus-badge badge-partial">تمويل جزئي</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- ═══ SCHOLARSHIPS ═══ -->
    <section id="scholarships">
        <div class="section-header center reveal">
            <span class="section-tag">🎓 منح مميزة</span>
            <h2 class="section-title">منحة مميزة</h2>
            <p class="section-sub">استكشف واحدة من أقوى المنح الدراسية المتاحة حالياً</p>
        </div>

        <div class="schol-grid" style="justify-content:center;">

            <div class="schol-card reveal" style="max-width:500px; margin:auto;">

                <div class="schol-country-flag">
                    <span class="flag-emoji">🇹🇷</span>
                    <span class="country-name">تركيا</span>
                </div>

                <div class="schol-name">المنحة التركية الحكومية</div>

                <div class="schol-meta">
                    <span class="tag tag-level">
                        <i class="fas fa-graduation-cap"></i> بكالوريوس / ماجستير / دكتوراه
                    </span>

                    <span class="tag tag-full">
                        <i class="fas fa-check-circle"></i> تمويل كامل
                    </span>

                    <span class="tag tag-deadline">
                        <i class="fas fa-calendar"></i> يناير 2026
                    </span>
                </div>

                <p class="schol-desc">
                    واحدة من أقوى المنح الحكومية في العالم، تقدم تمويلًا كاملاً يشمل الدراسة، السكن، الراتب الشهري، التأمين الصحي، وتذاكر السفر.
                </p>

            </div>

        </div>

        <!-- 🔥 زرار كل المنح -->
        <div style="text-align:center; margin-top: 44px;" class="reveal">
            <a class="btn-primary" href="/Scholarships" style="font-size:1rem; padding: 14px 38px;">
                <i class="fas fa-th-large" style="margin-left:8px;"></i> عرض جميع المنح
            </a>
        </div>
    </section>

    <!-- ═══ HOW IT WORKS ═══ -->
    <section id="how-it-works">
        <div class="section-header center reveal">
            <span class="section-tag">⚙️ مراحل المنصة</span>
            <h2 class="section-title">كيف تساعدك المنصة؟</h2>
            <p class="section-sub">أربع خطوات بسيطة تقودك من البحث عن المنحة إلى قبولك فيها</p>
        </div>

        <div class="steps-grid">
            <div class="step-card reveal">
                <div class="step-number">1</div>
                <div class="step-icon s1"><i class="fas fa-search"></i></div>
                <div class="step-title">تصفح وتقدم</div>
                <p class="step-desc">ابحث في قاعدة بياناتنا عن المنح المناسبة لتخصصك ومستواك الدراسي، وتقدم بخطوات سهلة من المنصة مباشرة.</p>
            </div>

            <div class="step-card reveal">
                <div class="step-number">2</div>
                <div class="step-icon s2"><i class="fas fa-user-tie"></i></div>
                <div class="step-title">استشارة مع خبير</div>
                <p class="step-desc">تواصل مع طلاب حاصلين على نفس المنحة من قبل، احصل على نصائح ذهبية حول التقديم، وكيفية تحضير ملفك بقوة.</p>
            </div>

            <div class="step-card reveal">
                <div class="step-number">3</div>
                <div class="step-icon s3"><i class="fas fa-users"></i></div>
                <div class="step-title">انضم للمجتمع</div>
                <p class="step-desc">كن جزءًا من مجموعات الطلاب الحاصلين على نفس المنحة، تبادل الخبرات، وابنِ علاقات تدوم مدى الحياة.</p>
            </div>

            <div class="step-card reveal">
                <div class="step-number">4</div>
                <div class="step-icon s4"><i class="fas fa-hands-helping"></i></div>
                <div class="step-title">دعم متكامل</div>
                <p class="step-desc">تقدم عبر مكاتب منصتنا المتخصصة التي تساعدك في إعداد ملفك، مراسلة الجامعات، وإتمام إجراءات القبول.</p>
            </div>
        </div>
    </section>

    <!-- ═══ TESTIMONIALS ═══ -->
    <section id="testimonials">
        <div class="section-header center reveal">
            <span class="section-tag">💬 قصص نجاح</span>
            <h2 class="section-title">ماذا يقول طلابنا؟</h2>
            <p class="section-sub">آلاف الطلاب العرب حققوا حلمهم بالدراسة في الخارج بمساعدة منصتنا</p>
        </div>

        <div class="testi-grid">
            <div class="testi-card reveal">
                <div class="testi-quote">"</div>
                <p class="testi-text">بفضل المنصة تمكنت من العثور على منحة فولبرايت وتحضير ملف قوي بإرشاد خبير حاصل عليها. الآن أنا في جامعة هارفارد!</p>
                <div class="testi-author">
                    <div class="avatar av1">أ</div>
                    <div>
                        <div class="testi-name">أميرة الزهراني</div>
                        <div class="testi-where">🇺🇸 جامعة هارفارد — ماجستير إدارة أعمال</div>
                        <div class="stars">★★★★★</div>
                    </div>
                </div>
            </div>

            <div class="testi-card reveal">
                <div class="testi-quote">"</div>
                <p class="testi-text">كنت أعتقد أن الحصول على منحة ألمانية صعب جداً، لكن الاستشارة المجانية مع متخصص غيّرت كل شيء. أنا الآن أدرس في ميونيخ!</p>
                <div class="testi-author">
                    <div class="avatar av2">م</div>
                    <div>
                        <div class="testi-name">محمد العمري</div>
                        <div class="testi-where">🇩🇪 جامعة ميونيخ التقنية — هندسة</div>
                        <div class="stars">★★★★★</div>
                    </div>
                </div>
            </div>

            <div class="testi-card reveal">
                <div class="testi-quote">"</div>
                <p class="testi-text">المنصة وفّرت لي كل ما أحتاجه: البحث، الاستشارة، والمتابعة. فريق الدعم كان متاحًا دائمًا للإجابة على أسئلتي. شكرًا جزيلاً!</p>
                <div class="testi-author">
                    <div class="avatar av3">س</div>
                    <div>
                        <div class="testi-name">سارة الخليل</div>
                        <div class="testi-where">🇬🇧 جامعة أكسفورد — دكتوراه علوم</div>
                        <div class="stars">★★★★★</div>
                    </div>
                </div>
            </div>

            <div class="testi-card reveal">
                <div class="testi-quote">"</div>
                <p class="testi-text">كانت لديّ حيرة بين عدة منح، والمنصة ساعدتني في اتخاذ القرار الصحيح. المجتمع الطلابي رائع ومحفز جداً!</p>
                <div class="testi-author">
                    <div class="avatar av4">ي</div>
                    <div>
                        <div class="testi-name">يوسف البلوشي</div>
                        <div class="testi-where">🇯🇵 جامعة طوكيو — دراسات عليا</div>
                        <div class="stars">★★★★★</div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- ═══ CTA ═══ -->
    <section id="cta">
        <div class="cta-box reveal">
            <span class="section-tag">🚀 ابدأ رحلتك</span>
            <h2 class="section-title" style="margin-bottom:16px;">حلمك بالدراسة في الخارج يبدأ هنا</h2>
            <p>سجل الآن مجانًا واستكشف مئات المنح المتاحة لك. فريقنا من الخبراء جاهز لمساعدتك في كل خطوة.</p>
            <div class="cta-btns">
                <a class="btn-cta-white" asp-controller="Account" asp-action="Register">
                    <i class="fas fa-user-plus"></i>
                    سجّل مجانًا الآن
                </a>                <a class="btn-cta-outline" href="#scholarships"><i class="fas fa-search" style="margin-left:8px;"></i> تصفح المنح</a>
            </div>
        </div>
    </section>

    <!-- ═══ FOOTER ═══ -->
    <footer>
        <div class="footer-inner">
            <div class="footer-brand">
                <a class="nav-logo" href="#">
                    <div class="logo-icon"><i class="fas fa-graduation-cap"></i></div>
                    <span>منصة المنح العربية</span>
                </a>
                <p>منصتك الأولى للبحث عن المنح الدراسية الدولية ودعم الطلاب العرب في رحلتهم نحو التميز الأكاديمي.</p>
                <div class="social-links">
                    <a class="social-link" href="#"><i class="fab fa-twitter"></i></a>
                    <a class="social-link" href="#"><i class="fab fa-instagram"></i></a>
                    <a class="social-link" href="#"><i class="fab fa-facebook-f"></i></a>
                    <a class="social-link" href="#"><i class="fab fa-youtube"></i></a>
                    <a class="social-link" href="#"><i class="fab fa-linkedin-in"></i></a>
                </div>
            </div>

            <div class="footer-col">
                <h4>المنصة</h4>
                <ul>
                    <li><a href="#">عن المنصة</a></li>
                    <li><a href="#">كيف تعمل؟</a></li>
                    <li><a href="#">فريق العمل</a></li>
                    <li><a href="#">مدونة المنح</a></li>
                </ul>
            </div>

            <div class="footer-col">
                <h4>الخدمات</h4>
                <ul>
                    <li><a href="#">تصفح المنح</a></li>
                    <li><a href="#">الاستشارات المجانية</a></li>
                    <li><a href="#">مجتمعات الطلاب</a></li>
                    <li><a href="#">دعم التقديم</a></li>
                </ul>
            </div>

            <div class="footer-col">
                <h4>الدعم والقانوني</h4>
                <ul>
                    <li><a href="#">تواصل معنا</a></li>
                    <li><a href="#">الأسئلة الشائعة</a></li>
                    <li><a href="#">سياسة الخصوصية</a></li>
                    <li><a href="#">شروط الاستخدام</a></li>
                </ul>
            </div>
        </div>

        <div class="footer-bottom">
            <p>© 2025 منصة Granto. جميع الحقوق محفوظة.</p>
            <p>صُمّمت بـ ❤️ لكل طالب عربي يسعى للتميز</p>
        </div>
    </footer>

    <script>
        // Navbar scroll effect
        const navbar = document.getElementById('navbar');
        window.addEventListener('scroll', () => {
          navbar.classList.toggle('scrolled', window.scrollY > 20);
        });

        // Mobile hamburger
        const hamburger = document.getElementById('hamburger');
        const navLinks = document.getElementById('navLinks');
        hamburger.addEventListener('click', () => {
          navLinks.classList.toggle('open');
        });
        document.addEventListener('click', e => {
          if (!navbar.contains(e.target)) navLinks.classList.remove('open');
        });

        // Scroll reveal
        const revealObserver = new IntersectionObserver((entries) => {
          entries.forEach((entry, i) => {
            if (entry.isIntersecting) {
              entry.target.style.transitionDelay = (i * 0.08) + 's';
              entry.target.classList.add('visible');
              revealObserver.unobserve(entry.target);
            }
          });
        }, { threshold: 0.12 });

        document.querySelectorAll('.reveal').forEach(el => revealObserver.observe(el));

        // Smooth close nav on link click (mobile)
        navLinks.querySelectorAll('a').forEach(a => {
          a.addEventListener('click', () => navLinks.classList.remove('open'));
        });
    </script>
</body>
</html>