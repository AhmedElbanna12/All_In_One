@model IEnumerable<AllinOne.Models.Scholarship>
@{
    ViewData["Title"] = "قائمة المنح";
}

<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] — منصة المنح العربية</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Tajawal:wght@300;400;500;700;800;900&family=Cairo:wght@400;600;700;900&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" />
    <link rel="stylesheet" href="~/css/scholarships.css" />
</head>
<body>

    <div class="page-wrapper wide">

        <div class="breadcrumb">
            <a href="/"><i class="fas fa-home"></i> الرئيسية</a>
            <span class="sep"><i class="fas fa-chevron-left"></i></span>
            <span class="current">المنح الدراسية</span>
        </div>

        <div class="page-header">
            <div class="page-header-left">
                <div class="page-icon"><i class="fas fa-graduation-cap"></i></div>
                <div class="page-title">
                    <h1>المنح الدراسية</h1>
                    <p>إدارة وعرض جميع المنح المتاحة على المنصة</p>
                </div>
            </div>
            <a asp-action="Create" class="btn btn-success">
                <i class="fas fa-plus"></i> إنشاء منحة جديدة
            </a>
        </div>

        <div class="table-card">

            <div class="table-toolbar">
                <div class="table-search">
                    <input type="text" id="searchInput" placeholder="ابحث عن منحة..." />
                    <i class="fas fa-search"></i>
                </div>
                <div class="table-count">
                    إجمالي المنح: <span id="rowCount">@Model.Count()</span>
                </div>
            </div>

            <div style="overflow-x: auto;">
                <table class="data-table" id="scholarshipsTable">
                    <thead>
                        <tr>
                            <th>#</th>
                            <th><i class="fas fa-heading"></i> العنوان</th>
                            <th><i class="fas fa-globe"></i> البلد</th>
                            <th><i class="fas fa-coins"></i> التمويل</th>
                            <th><i class="fas fa-user-graduate"></i> المستوى</th>
                            <th><i class="fas fa-calendar-alt"></i> الموعد النهائي</th>
                            <th><i class="fas fa-star"></i> مميزة</th>
                            <th><i class="fas fa-cog"></i> إجراءات</th>
                        </tr>
                    </thead>
                    <tbody>
                        @{
                            int i = 1;
                        }
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td style="color:var(--text-muted); font-size:.82rem;">@i</td>
                                <td style="font-weight:600; max-width:220px;">@item.Title</td>
                                <td>
                                    <span class="badge badge-teal">
                                        <i class="fas fa-map-marker-alt"></i> @item.Country
                                    </span>
                                </td>
                                <td>
                                    <span class="badge badge-accent">@item.FundingType</span>
                                </td>
                                <td>@item.DegreeLevel</td>
                                <td>
                                    <span class="badge badge-teal">
                                        <i class="fas fa-clock"></i> @item.Deadline.ToShortDateString()
                                    </span>
                                </td>
                                <td>
                                    @if (item.Featured)
                                    {
                                        <span class="badge badge-success"><i class="fas fa-star"></i> نعم</span>
                                    }
                                    else
                                    {
                                        <span class="badge badge-muted">لا</span>
                                    }
                                </td>
                                <td>
                                    <div class="actions-cell">
                                        <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-warning">
                                            <i class="fas fa-edit"></i> تعديل
                                        </a>
                                        <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-danger">
                                            <i class="fas fa-trash"></i> حذف
                                        </a>
                                    </div>
                                </td>
                            </tr>
                            i++;
                        }
                    </tbody>
                </table>
            </div>

            <div class="table-footer">
                <span style="font-size:.82rem; color:var(--text-muted);">
                    إجمالي <strong>@Model.Count()</strong> منحة مسجلة
                </span>
            </div>

        </div>
    </div>

    <script>
        const searchInput = document.getElementById('searchInput');
        const rows = document.querySelectorAll('#scholarshipsTable tbody tr');
        const rowCount = document.getElementById('rowCount');

        searchInput.addEventListener('input', function () {
            const term = this.value.toLowerCase();
            let visible = 0;
            rows.forEach(row => {
                const match = row.textContent.toLowerCase().includes(term);
                row.style.display = match ? '' : 'none';
                if (match) visible++;
            });
            rowCount.textContent = visible;
        });
    </script>

</body>
</html>