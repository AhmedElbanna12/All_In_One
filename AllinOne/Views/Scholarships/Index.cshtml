@model IEnumerable<AllinOne.Models.Scholarship>
@{
    ViewData["Title"] = "قائمة المنح";
}

<h2>@ViewData["Title"]</h2>

<p>
    <a asp-action="Create" class="btn btn-primary">إنشاء منحة جديدة</a>
</p>

<table class="table table-bordered table-striped">
    <thead>
        <tr>
            <th>العنوان</th>
            <th>البلد</th>
            <th>التمويل</th>
            <th>المستوى الدراسي</th>
            <th>تاريخ الانتهاء</th>
            <th>مميزة</th>
            <th>إجراءات</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.Title</td>
                <td>@item.Country</td>
                <td>@item.FundingType</td>
                <td>@item.DegreeLevel</td>
                <td>@item.Deadline.ToShortDateString()</td>
                <td>@(item.Featured ? "نعم" : "لا")</td>
                <td>
                    <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-warning">تعديل</a>
                    <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-danger">حذف</a>
                </td>
            </tr>
        }
    </tbody>
</table>