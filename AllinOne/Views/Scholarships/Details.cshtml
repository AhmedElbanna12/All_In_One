@model AllinOne.Models.Scholarship

@{
    ViewData["Title"] = Model.Title;
}

<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@Model.Title</title>
    <link href="https://fonts.googleapis.com/css2?family=Tajawal:wght@300;400;500;700;800;900&display=swap" rel="stylesheet" />
    <style>
        *, *::before, *::after {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Tajawal', sans-serif;
            background: #f1f5f9;
            color: #1e293b;
            overflow-x: hidden;
        }

        /* ── PROGRESS BAR ── */
        .progress-bar {
            position: fixed;
            top: 0;
            right: 0;
            height: 3px;
            width: 0%;
            background: linear-gradient(90deg, #3b82f6, #06b6d4);
            z-index: 9999;
            transition: width 0.1s linear;
        }

        /* ── HERO ── */
        .hero-wrapper {
            position: relative;
            overflow: hidden;
            padding: 70px 0 0;
        }

            .hero-wrapper::before {
                content: '';
                position: absolute;
                inset: 0;
                background: linear-gradient(135deg, #0f172a 0%, #1e3a5f 55%, #0c4a6e 100%);
            }

            .hero-wrapper::after {
                content: '';
                position: absolute;
                inset: 0;
                background-image: linear-gradient(rgba(59,130,246,0.07) 1px, transparent 1px), linear-gradient(90deg, rgba(59,130,246,0.07) 1px, transparent 1px);
                background-size: 44px 44px;
            }

        .orb {
            position: absolute;
            border-radius: 50%;
            filter: blur(80px);
            opacity: 0.14;
            pointer-events: none;
        }

        .orb-1 {
            width: 560px;
            height: 560px;
            background: #3b82f6;
            top: -200px;
            right: -120px;
        }

        .orb-2 {
            width: 380px;
            height: 380px;
            background: #06b6d4;
            bottom: -80px;
            left: -80px;
        }

        .orb-3 {
            width: 260px;
            height: 260px;
            background: #f59e0b;
            top: 35%;
            left: 38%;
        }

        .particle {
            position: absolute;
            border-radius: 50%;
            background: rgba(96,165,250,0.35);
            pointer-events: none;
            animation: float-p 7s ease-in-out infinite;
        }

        @@keyframes float-p {
            0%, 100% {
                transform: translateY(0) scale(1);
                opacity: 0.35;
            }

            50% {
                transform: translateY(-28px) scale(1.2);
                opacity: 0.75;
            }
        }

        .hero-inner {
            position: relative;
            z-index: 2;
            max-width: 1120px;
            margin: 0 auto;
            padding: 0 30px 64px;
        }

        .badge-row {
            display: flex;
            flex-wrap: wrap;
            gap: 9px;
            margin-bottom: 22px;
            animation: slide-down 0.55s ease both;
        }

        .badge {
            display: inline-flex;
            align-items: center;
            gap: 5px;
            padding: 5px 14px;
            border-radius: 100px;
            font-size: 12.5px;
            font-weight: 600;
            backdrop-filter: blur(8px);
            border: 1px solid rgba(255,255,255,0.14);
            color: #fff;
            letter-spacing: 0.2px;
        }

        .badge-country {
            background: rgba(59,130,246,0.28);
            border-color: rgba(59,130,246,0.5);
        }

        .badge-funding {
            background: rgba(245,158,11,0.25);
            border-color: rgba(245,158,11,0.5);
        }

        .badge-degree {
            background: rgba(16,185,129,0.25);
            border-color: rgba(16,185,129,0.5);
        }

        .badge-deadline {
            background: rgba(239,68,68,0.25);
            border-color: rgba(239,68,68,0.5);
        }

        .hero-title {
            font-size: clamp(26px, 4.5vw, 50px);
            font-weight: 900;
            color: #fff;
            line-height: 1.2;
            margin-bottom: 16px;
            animation: slide-up 0.65s ease both;
            animation-delay: 0.08s;
        }

            .hero-title span {
                background: linear-gradient(90deg, #60a5fa, #22d3ee);
                -webkit-background-clip: text;
                -webkit-text-fill-color: transparent;
                background-clip: text;
            }

        .hero-desc {
            font-size: 16px;
            color: rgba(255,255,255,0.7);
            line-height: 1.85;
            max-width: 660px;
            margin-bottom: 30px;
            animation: slide-up 0.65s ease both;
            animation-delay: 0.16s;
        }

        .apply-btn {
            display: inline-flex;
            align-items: center;
            gap: 9px;
            padding: 13px 30px;
            background: linear-gradient(135deg, #10b981, #059669);
            color: #fff;
            font-family: 'Tajawal', sans-serif;
            font-size: 15px;
            font-weight: 700;
            border-radius: 13px;
            text-decoration: none;
            position: relative;
            overflow: hidden;
            box-shadow: 0 8px 28px rgba(16,185,129,0.42);
            transition: transform 0.22s, box-shadow 0.22s;
            animation: slide-up 0.65s ease both;
            animation-delay: 0.24s;
        }

            .apply-btn::before {
                content: '';
                position: absolute;
                inset: 0;
                background: rgba(255,255,255,0.12);
                opacity: 0;
                transition: opacity 0.25s;
            }

            .apply-btn:hover {
                transform: translateY(-3px);
                box-shadow: 0 14px 38px rgba(16,185,129,0.5);
            }

                .apply-btn:hover::before {
                    opacity: 1;
                }

            .apply-btn .arrow {
                transition: transform 0.25s;
            }

            .apply-btn:hover .arrow {
                transform: translateX(-5px);
            }

        /* wave */
        .wave-svg {
            display: block;
            position: relative;
            z-index: 2;
            margin-top: -2px;
        }

        /* ── CONTENT AREA ── */
        .content-wrap {
            max-width: 1120px;
            margin: 0 auto;
            padding: 0 30px 80px;
        }

        /* ── STATS ── */
        .stats-bar {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(155px, 1fr));
            gap: 14px;
            margin: -36px 0 38px;
            position: relative;
            z-index: 10;
        }

        .stat-card {
            background: #fff;
            border-radius: 16px;
            padding: 18px 20px;
            text-align: center;
            border: 1px solid #e2e8f0;
            box-shadow: 0 8px 32px rgba(0,0,0,0.07);
            animation: pop-in 0.5s cubic-bezier(0.175,0.885,0.32,1.275) both;
            transition: transform 0.28s, box-shadow 0.28s;
        }

            .stat-card:hover {
                transform: translateY(-5px);
                box-shadow: 0 18px 48px rgba(0,0,0,0.12);
            }

            .stat-card:nth-child(1) {
                animation-delay: 0.08s;
            }

            .stat-card:nth-child(2) {
                animation-delay: 0.15s;
            }

            .stat-card:nth-child(3) {
                animation-delay: 0.22s;
            }

            .stat-card:nth-child(4) {
                animation-delay: 0.29s;
            }

        .stat-icon {
            font-size: 26px;
            display: block;
            margin-bottom: 7px;
        }

        .stat-label {
            font-size: 11px;
            color: #94a3b8;
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: 0.5px;
            margin-bottom: 3px;
        }

        .stat-value {
            font-size: 14px;
            font-weight: 800;
            color: #0f172a;
        }

        /* ── TABS WRAPPER ── */
        .tabs-wrapper {
            background: #fff;
            border-radius: 20px;
            border: 1px solid #e2e8f0;
            box-shadow: 0 4px 22px rgba(0,0,0,0.055);
            overflow: hidden;
            animation: fade-in 0.55s ease both;
            animation-delay: 0.35s;
        }

        /* ── TAB NAV ── */
        .tabs-nav {
            display: flex;
            overflow-x: auto;
            background: #f8fafc;
            border-bottom: 1px solid #e2e8f0;
            padding: 8px 8px 0;
            gap: 4px;
            scrollbar-width: none;
        }

            .tabs-nav::-webkit-scrollbar {
                display: none;
            }

        .tab-btn {
            display: inline-flex;
            align-items: center;
            gap: 7px;
            padding: 11px 18px;
            border: none;
            background: transparent;
            color: #64748b;
            font-family: 'Tajawal', sans-serif;
            font-size: 14px;
            font-weight: 600;
            cursor: pointer;
            border-radius: 11px 11px 0 0;
            white-space: nowrap;
            transition: all 0.25s;
            position: relative;
        }

            .tab-btn::after {
                content: '';
                position: absolute;
                bottom: 0;
                right: 12%;
                left: 12%;
                height: 3px;
                background: #3b82f6;
                border-radius: 3px 3px 0 0;
                transform: scaleX(0);
                transition: transform 0.28s;
            }

            .tab-btn:hover {
                color: #3b82f6;
                background: rgba(59,130,246,0.06);
            }

            .tab-btn.active {
                color: #3b82f6;
                background: #fff;
            }

                .tab-btn.active::after {
                    transform: scaleX(1);
                }

        /* ── PANELS ── */
        .tab-panels {
            padding: 30px 32px;
        }

        .tab-panel {
            display: none;
        }

            .tab-panel.active {
                display: block;
                animation: panel-in 0.32s ease;
            }

        @@keyframes panel-in {
            from {
                opacity: 0;
                transform: translateY(10px);
            }

            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        .section-title {
            font-size: 19px;
            font-weight: 800;
            color: #0f172a;
            margin-bottom: 22px;
            display: flex;
            align-items: center;
            gap: 9px;
        }

            .section-title::after {
                content: '';
                flex: 1;
                height: 1.5px;
                background: linear-gradient(90deg, #e2e8f0, transparent);
                border-radius: 2px;
            }

        /* overview */
        .overview-text {
            font-size: 15.5px;
            line-height: 2;
            color: #374151;
        }

        /* majors */
        .majors-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(175px, 1fr));
            gap: 11px;
        }

        .major-card {
            background: linear-gradient(135deg, #eff6ff, #f0f9ff);
            border: 1px solid #bfdbfe;
            border-radius: 12px;
            padding: 13px 15px;
            font-size: 13.5px;
            font-weight: 600;
            color: #1d4ed8;
            display: flex;
            align-items: center;
            gap: 8px;
            transition: all 0.25s;
        }

            .major-card:hover {
                transform: translateY(-3px);
                background: linear-gradient(135deg, #dbeafe, #e0f2fe);
                box-shadow: 0 8px 20px rgba(59,130,246,0.13);
            }

        /* requirements */
        .req-list {
            list-style: none;
        }

        .req-item {
            display: flex;
            align-items: flex-start;
            gap: 13px;
            padding: 13px 0;
            border-bottom: 1px solid #f1f5f9;
            animation: slide-right 0.38s ease both;
        }

            .req-item:last-child {
                border-bottom: none;
            }

        .req-check {
            width: 30px;
            height: 30px;
            background: linear-gradient(135deg, #10b981, #059669);
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            color: #fff;
            font-size: 13px;
            flex-shrink: 0;
            margin-top: 1px;
        }

        .req-text {
            font-size: 14.5px;
            line-height: 1.7;
        }

        /* documents */
        .doc-list {
            list-style: none;
        }

        .doc-item {
            display: flex;
            gap: 15px;
            padding: 15px;
            background: #f8fafc;
            border-radius: 12px;
            margin-bottom: 10px;
            border: 1px solid #e2e8f0;
            transition: all 0.25s;
            animation: slide-right 0.38s ease both;
        }

            .doc-item:hover {
                border-color: #3b82f6;
                background: #eff6ff;
                transform: translateX(-4px);
            }

        .doc-num {
            width: 34px;
            height: 34px;
            background: linear-gradient(135deg, #3b82f6, #06b6d4);
            border-radius: 9px;
            display: flex;
            align-items: center;
            justify-content: center;
            color: #fff;
            font-weight: 800;
            font-size: 13px;
            flex-shrink: 0;
        }

        .doc-title {
            font-weight: 700;
            font-size: 13.5px;
            margin-bottom: 3px;
        }

        .doc-desc {
            font-size: 12.5px;
            color: #64748b;
            line-height: 1.55;
        }

        /* benefits */
        .benefits-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(210px, 1fr));
            gap: 13px;
        }

        .benefit-card {
            background: linear-gradient(135deg, #f0fdf4, #ecfdf5);
            border: 1px solid #a7f3d0;
            border-radius: 13px;
            padding: 16px;
            display: flex;
            align-items: flex-start;
            gap: 11px;
            transition: all 0.25s;
        }

            .benefit-card:hover {
                transform: translateY(-4px);
                box-shadow: 0 10px 28px rgba(16,185,129,0.14);
            }

        .benefit-check {
            width: 26px;
            height: 26px;
            background: linear-gradient(135deg, #10b981, #059669);
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            color: #fff;
            font-size: 12px;
            flex-shrink: 0;
        }

        .benefit-text {
            font-size: 13.5px;
            font-weight: 600;
            color: #065f46;
            line-height: 1.5;
        }

        /* stipends */
        .stipends-table {
            width: 100%;
            border-collapse: collapse;
            border-radius: 14px;
            overflow: hidden;
            box-shadow: 0 4px 18px rgba(0,0,0,0.06);
        }

            .stipends-table thead tr {
                background: linear-gradient(135deg, #0f172a, #1e3a5f);
                color: #fff;
            }

            .stipends-table th {
                padding: 15px 20px;
                font-size: 13.5px;
                font-weight: 700;
                text-align: right;
            }

            .stipends-table tbody tr {
                border-bottom: 1px solid #e2e8f0;
                transition: background 0.2s;
            }

                .stipends-table tbody tr:hover {
                    background: #eff6ff;
                }

            .stipends-table td {
                padding: 13px 20px;
                font-size: 14.5px;
            }

        .amount-val {
            font-weight: 800;
            color: #3b82f6;
            font-size: 16px;
        }

        .amount-unit {
            font-size: 11px;
            color: #94a3b8;
            font-weight: 500;
            margin-right: 3px;
        }

        /* ── FAB ── */
        .fab {
            position: fixed;
            bottom: 28px;
            left: 28px;
            width: 48px;
            height: 48px;
            background: #0f172a;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            color: #fff;
            font-size: 20px;
            text-decoration: none;
            box-shadow: 0 8px 24px rgba(0,0,0,0.28);
            opacity: 0;
            transform: scale(0);
            transition: all 0.28s;
            z-index: 200;
        }

            .fab.show {
                opacity: 1;
                transform: scale(1);
            }

            .fab:hover {
                background: #3b82f6;
                transform: scale(1.1);
            }

        /* ── ANIMATIONS ── */
        @@keyframes slide-up {
            from {
                opacity: 0;
                transform: translateY(28px);
            }

            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        @@keyframes slide-down {
            from {
                opacity: 0;
                transform: translateY(-18px);
            }

            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        @@keyframes slide-right {
            from {
                opacity: 0;
                transform: translateX(18px);
            }

            to {
                opacity: 1;
                transform: translateX(0);
            }
        }

        @@keyframes pop-in {
            from {
                opacity: 0;
                transform: scale(0.82) translateY(18px);
            }

            to {
                opacity: 1;
                transform: scale(1) translateY(0);
            }
        }

        @@keyframes fade-in {
            from {
                opacity: 0;
            }

            to {
                opacity: 1;
            }
        }

        @@media (max-width: 640px) {
            .hero-inner {
                padding: 0 18px 52px;
            }

            .content-wrap {
                padding: 0 18px 60px;
            }

            .tab-panels {
                padding: 20px;
            }

            .stats-bar {
                grid-template-columns: repeat(2, 1fr);
            }
        }
    </style>
</head>
<body>

    <div class="progress-bar" id="progress"></div>

    <!-- ── HERO ── -->
    <div class="hero-wrapper">
        <div class="orb orb-1"></div>
        <div class="orb orb-2"></div>
        <div class="orb orb-3"></div>

        <div class="particle" style="width:7px;height:7px;top:18%;right:14%;animation-delay:0s"></div>
        <div class="particle" style="width:5px;height:5px;top:55%;right:28%;animation-delay:-2.5s"></div>
        <div class="particle" style="width:9px;height:9px;top:32%;right:58%;animation-delay:-4s"></div>
        <div class="particle" style="width:6px;height:6px;top:68%;right:74%;animation-delay:-1.2s"></div>
        <div class="particle" style="width:8px;height:8px;top:12%;right:44%;animation-delay:-3s"></div>

        <div class="hero-inner">
            <div class="badge-row">
                <span class="badge badge-country">🌍 @Model.Country</span>
                <span class="badge badge-funding">💰 @Model.FundingType</span>
                <span class="badge badge-degree">🎓 @Model.DegreeLevel</span>
                <span class="badge badge-deadline">📅 @Model.Deadline.ToShortDateString()</span>
            </div>

            <h1 class="hero-title"><span>@Model.Title</span></h1>
            <p class="hero-desc">@Model.ShortDescription</p>

            <a href="@Model.OfficialLink" target="_blank" class="apply-btn">
                <i class="arrow">←</i> قدّم طلبك الآن
            </a>
        </div>

        <svg class="wave-svg" viewBox="0 0 1440 64" xmlns="http://www.w3.org/2000/svg">
            <path d="M0,0 C360,64 1080,64 1440,0 L1440,64 L0,64 Z" fill="#f1f5f9" />
        </svg>
    </div>

    <!-- ── CONTENT ── -->
    <div class="content-wrap">

        <!-- stats -->
        <div class="stats-bar">
            <div class="stat-card">
                <span class="stat-icon">🌍</span>
                <div class="stat-label">الدولة</div>
                <div class="stat-value">@Model.Country</div>
            </div>
            <div class="stat-card">
                <span class="stat-icon">💰</span>
                <div class="stat-label">نوع التمويل</div>
                <div class="stat-value">@Model.FundingType</div>
            </div>
            <div class="stat-card">
                <span class="stat-icon">🎓</span>
                <div class="stat-label">المرحلة</div>
                <div class="stat-value">@Model.DegreeLevel</div>
            </div>
            <div class="stat-card">
                <span class="stat-icon">⏳</span>
                <div class="stat-label">آخر موعد</div>
                <div class="stat-value" style="color:#ef4444">@Model.Deadline.ToShortDateString()</div>
            </div>
        </div>

        <!-- tabs -->
        <div class="tabs-wrapper">

            <nav class="tabs-nav">
                <button class="tab-btn active" onclick="switchTab(event,'overview')">📄 نظرة عامة</button>
                <button class="tab-btn" onclick="switchTab(event,'majors')">🎓 التخصصات</button>
                <button class="tab-btn" onclick="switchTab(event,'requirements')">📌 الشروط</button>
                <button class="tab-btn" onclick="switchTab(event,'documents')">📂 الأوراق</button>
                <button class="tab-btn" onclick="switchTab(event,'benefits')">💎 المميزات</button>
                <button class="tab-btn" onclick="switchTab(event,'stipends')">💰 الرواتب</button>
            </nav>

            <div class="tab-panels">

                <div id="overview" class="tab-panel active">
                    <h2 class="section-title">📄 نظرة عامة</h2>
                    <p class="overview-text">@Model.FullDescription</p>
                </div>

                <div id="majors" class="tab-panel">
                    <h2 class="section-title">🎓 التخصصات المتاحة</h2>
                    <div class="majors-grid">
                        @foreach (var m in Model.Majors)
                        {
                            <div class="major-card">🎓 @m.Name</div>
                        }
                    </div>
                </div>

                <div id="requirements" class="tab-panel">
                    <h2 class="section-title">📌 شروط التقديم</h2>
                    <ul class="req-list">
                        @{
                            int ri = 0;
                        }
                        @foreach (var r in Model.Requirements)
                        {
                            ri++;
                            <li class="req-item" style="animation-delay:@(ri * 0.07)s">
                                <div class="req-check">✓</div>
                                <span class="req-text">@r.Description</span>
                            </li>
                        }
                    </ul>
                </div>

                <div id="documents" class="tab-panel">
                    <h2 class="section-title">📂 الأوراق المطلوبة</h2>
                    <ul class="doc-list">
                        @{
                            int di = 0;
                        }
                        @foreach (var d in Model.Documents)
                        {
                            di++;
                            <li class="doc-item" style="animation-delay:@(di * 0.08)s">
                                <div class="doc-num">@di</div>
                                <div>
                                    <div class="doc-title">@d.Title</div>
                                    <div class="doc-desc">@d.Description</div>
                                </div>
                            </li>
                        }
                    </ul>
                </div>

                <div id="benefits" class="tab-panel">
                    <h2 class="section-title">💎 مميزات المنحة</h2>
                    <div class="benefits-grid">
                        @foreach (var b in Model.Benefits)
                        {
                            <div class="benefit-card">
                                <div class="benefit-check">✓</div>
                                <span class="benefit-text">@b.Description</span>
                            </div>
                        }
                    </div>
                </div>

                <div id="stipends" class="tab-panel">
                    <h2 class="section-title">💰 الرواتب والمكافآت</h2>
                    <table class="stipends-table">
                        <thead>
                            <tr>
                                <th>مستوى الدراسة</th>
                                <th>المبلغ الشهري</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var s in Model.Stipends)
                            {
                                <tr>
                                    <td>@s.DegreeLevel</td>
                                    <td>
                                        <span class="amount-val">@s.Amount</span>
                                        <span class="amount-unit">ليرة</span>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>

            </div>
        </div>
    </div>

    <a class="fab" id="fab" href="#">↑</a>

    <script>
        function switchTab(e, id) {
            document.querySelectorAll('.tab-panel').forEach(p => p.classList.remove('active'));
            document.querySelectorAll('.tab-btn').forEach(b => b.classList.remove('active'));
            document.getElementById(id).classList.add('active');
            e.currentTarget.classList.add('active');
        }

        window.addEventListener('scroll', () => {
            const pct = window.scrollY / (document.body.scrollHeight - innerHeight) * 100;
            document.getElementById('progress').style.width = pct + '%';
            const fab = document.getElementById('fab');
            window.scrollY > 280 ? fab.classList.add('show') : fab.classList.remove('show');
        });

        document.querySelectorAll('.req-item, .doc-item, .major-card, .benefit-card')
            .forEach((el, i) => el.style.animationDelay = (i * 0.055) + 's');
    </script>

</body>
</html>