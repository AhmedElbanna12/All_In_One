@model AllinOne.Models.Community
@inject Microsoft.AspNetCore.Antiforgery.IAntiforgery Antiforgery

@{
    var userIsMember = ViewBag.IsMember as bool? ?? false;
    var token = Antiforgery.GetAndStoreTokens(Context).RequestToken;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta name="csrf-token" content="@token" />
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@Model.Name — Chat</title>
    <link href="https://fonts.googleapis.com/css2?family=Sora:wght@300;400;500;600&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />
    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/7.0.5/signalr.min.js"></script>
    <style>
        :root {
            --bg: #0d0f14;
            --surface: #161a23;
            --border: #252b38;
            --accent: #4f8ef7;
            --accent2: #7c5cfc;
            --text: #e4e8f0;
            --muted: #7a8499;
            --online: #3dd68c;
            --self-bg: #1a2a4a;
            --other-bg: #1e2230;
            --danger: #f76f6f;
            --radius: 14px;
            --font: 'Sora', sans-serif;
            --mono: 'JetBrains Mono', monospace;
        }

        *, *::before, *::after {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
        }

        body {
            font-family: var(--font);
            background: var(--bg);
            color: var(--text);
            height: 100vh;
            display: flex;
            flex-direction: column;
            overflow: hidden;
        }

        .chat-header {
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 14px 24px;
            background: var(--surface);
            border-bottom: 1px solid var(--border);
            flex-shrink: 0;
            gap: 12px;
        }

            .chat-header h2 {
                font-size: 1.05rem;
                font-weight: 600;
                letter-spacing: .02em;
                background: linear-gradient(135deg, var(--accent), var(--accent2));
                -webkit-background-clip: text;
                -webkit-text-fill-color: transparent;
            }

        #joinBtn {
            padding: 8px 20px;
            background: linear-gradient(135deg, var(--accent), var(--accent2));
            border: none;
            border-radius: 8px;
            color: #fff;
            font-family: var(--font);
            font-size: .85rem;
            font-weight: 500;
            cursor: pointer;
            transition: opacity .2s, transform .15s;
        }

            #joinBtn:hover {
                opacity: .88;
                transform: translateY(-1px);
            }

            #joinBtn:active {
                transform: translateY(0);
            }

        #chatContainer {
            display: flex;
            flex: 1;
            overflow: hidden;
        }

        #chatBox {
            flex: 1;
            display: flex;
            flex-direction: column;
            overflow: hidden;
        }

        #messages {
            flex: 1;
            overflow-y: auto;
            padding: 20px 24px;
            display: flex;
            flex-direction: column;
            gap: 10px;
            scroll-behavior: smooth;
        }

            #messages::-webkit-scrollbar {
                width: 6px;
            }

            #messages::-webkit-scrollbar-track {
                background: transparent;
            }

            #messages::-webkit-scrollbar-thumb {
                background: var(--border);
                border-radius: 4px;
            }

        .msg-wrapper {
            display: flex;
            flex-direction: column;
            max-width: 68%;
            animation: fadeUp .25s ease both;
        }

            .msg-wrapper.self {
                align-self: flex-end;
                align-items: flex-end;
            }

            .msg-wrapper.other {
                align-self: flex-start;
                align-items: flex-start;
            }

        @@keyframes fadeUp {
            from {
                opacity: 0;
                transform: translateY(8px);
            }

            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        .msg-meta {
            font-size: .7rem;
            color: var(--muted);
            margin-bottom: 4px;
            font-family: var(--mono);
        }

        .msg-bubble {
            padding: 10px 14px;
            border-radius: var(--radius);
            font-size: .88rem;
            line-height: 1.5;
            word-break: break-word;
        }

        .self .msg-bubble {
            background: var(--self-bg);
            border: 1px solid rgba(79,142,247,.25);
            border-bottom-right-radius: 4px;
        }

        .other .msg-bubble {
            background: var(--other-bg);
            border: 1px solid var(--border);
            border-bottom-left-radius: 4px;
        }

        .msg-time {
            font-size: .65rem;
            color: var(--muted);
            margin-top: 3px;
            font-family: var(--mono);
        }

        #guestBanner {
            margin: 20px 24px;
            padding: 18px 22px;
            background: var(--surface);
            border: 1px dashed var(--border);
            border-radius: var(--radius);
            color: var(--muted);
            font-size: .88rem;
            text-align: center;
            line-height: 1.6;
        }

        #typingIndicator {
            padding: 4px 24px 8px;
            font-size: .75rem;
            color: var(--accent);
            font-family: var(--mono);
            min-height: 22px;
        }

        #inputRow {
            display: flex;
            align-items: center;
            gap: 10px;
            padding: 12px 18px;
            border-top: 1px solid var(--border);
            background: var(--surface);
        }

        #messageInput {
            flex: 1;
            background: var(--bg);
            border: 1px solid var(--border);
            border-radius: 10px;
            padding: 10px 14px;
            color: var(--text);
            font-family: var(--font);
            font-size: .88rem;
            outline: none;
            transition: border-color .2s;
        }

            #messageInput::placeholder {
                color: var(--muted);
            }

            #messageInput:focus {
                border-color: var(--accent);
            }

        #sendBtn {
            width: 40px;
            height: 40px;
            border-radius: 10px;
            border: none;
            background: linear-gradient(135deg, var(--accent), var(--accent2));
            color: #fff;
            cursor: pointer;
            display: flex;
            align-items: center;
            justify-content: center;
            flex-shrink: 0;
            transition: opacity .2s, transform .15s;
        }

            #sendBtn:hover {
                opacity: .88;
                transform: translateY(-1px);
            }

        #onlineUsersBox {
            width: 200px;
            flex-shrink: 0;
            background: var(--surface);
            border-left: 1px solid var(--border);
            display: flex;
            flex-direction: column;
            overflow: hidden;
        }

            #onlineUsersBox h4 {
                padding: 14px 16px 10px;
                font-size: .8rem;
                font-weight: 600;
                letter-spacing: .08em;
                text-transform: uppercase;
                color: var(--muted);
                border-bottom: 1px solid var(--border);
            }

        #onlineUsers {
            list-style: none;
            overflow-y: auto;
            padding: 10px 0;
            flex: 1;
        }

            #onlineUsers li {
                display: flex;
                align-items: center;
                gap: 8px;
                padding: 7px 16px;
                font-size: .82rem;
                color: var(--text);
            }

                #onlineUsers li::before {
                    content: '';
                    width: 7px;
                    height: 7px;
                    border-radius: 50%;
                    background: var(--online);
                    flex-shrink: 0;
                    box-shadow: 0 0 6px var(--online);
                }

        #toast {
            position: fixed;
            bottom: 24px;
            left: 50%;
            transform: translateX(-50%) translateY(60px);
            background: var(--danger);
            color: #fff;
            padding: 10px 20px;
            border-radius: 8px;
            font-size: .83rem;
            opacity: 0;
            transition: all .3s ease;
            pointer-events: none;
            z-index: 9999;
        }

            #toast.show {
                opacity: 1;
                transform: translateX(-50%) translateY(0);
            }

        @@media (max-width: 600px) {
            #onlineUsersBox {
                display: none;
            }

            .msg-wrapper {
                max-width: 88%;
            }
        }
    </style>
</head>
<body>

    <div class="chat-header">
        <h2>#&thinsp;@Model.Name</h2>
        @if (!userIsMember)
        {
            <button id="joinBtn" onclick="joinCommunity()">Join Community</button>
        }
    </div>

    <div id="chatContainer">
        <div id="chatBox">
            <div id="messages"></div>

            @if (!userIsMember)
            {
                <div id="guestBanner">
                    Join this community to read and send messages.
                </div>
            }

            <div id="typingIndicator"></div>

            @if (userIsMember)
            {
                <div id="inputRow">
                    <input type="text" id="messageInput"
                           placeholder="Write a message…"
                           onkeydown="handleKey(event)"
                           oninput="typing()" />
                    <button id="sendBtn" onclick="sendMessage()" title="Send">
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none"
                             stroke="currentColor" stroke-width="2.2"
                             stroke-linecap="round" stroke-linejoin="round">
                            <line x1="22" y1="2" x2="11" y2="13" />
                            <polygon points="22 2 15 22 11 13 2 9 22 2" />
                        </svg>
                    </button>
                </div>
            }
        </div>

        <div id="onlineUsersBox">
            <h4>Online</h4>
            <ul id="onlineUsers"></ul>
        </div>
    </div>

    <div id="toast"></div>

    <script>
        const communityId = @Model.Id;
        let isMember = @userIsMember.ToString().ToLower();
        let typingTimer = null;
        const currentUserId = '@User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value';

        const connection = new signalR.HubConnectionBuilder()
            .withUrl("/communityChatHub")
            .withAutomaticReconnect()
            .build();

        connection.on("ReceiveMessage", (data) => {
            appendMessage(data.senderName, data.message, data.sentAt, data.senderId === currentUserId);
        });

        connection.on("UpdateOnlineUsers", (users) => {
            const ul = document.getElementById("onlineUsers");
            ul.innerHTML = users.map(u => `<li>${escHtml(u)}</li>`).join('');
        });

        connection.on("UserTyping", (name) => {
            const el = document.getElementById("typingIndicator");
            el.textContent = `${name} is typing…`;
            clearTimeout(typingTimer);
            typingTimer = setTimeout(() => el.textContent = '', 2500);
        });

        (async () => {
            try {
                await connection.start();
                if (isMember) {
                    await connection.invoke("JoinCommunity", communityId);
                    loadMessages();
                }
            } catch (e) {
                showToast("Connection failed. Please refresh.");
            }
        })();

        async function loadMessages() {
            try {
                const res = await fetch(`/api/CommunityChat/GetMessages?communityId=${communityId}`);
                if (!res.ok) return;
                const msgs = await res.json();
                msgs.forEach(m => appendMessage(m.senderName, m.message, m.sentAt, m.senderId === currentUserId));
            } catch { /* silent */ }
        }

        function appendMessage(sender, message, sentAt, isSelf) {
            const container = document.getElementById("messages");
            const time = new Date(sentAt).toLocaleTimeString([], { hour: '2-digit', minute: '2-digit' });
            const wrapper = document.createElement("div");
            wrapper.className = `msg-wrapper ${isSelf ? 'self' : 'other'}`;
            wrapper.innerHTML = `
                ${!isSelf ? `<span class="msg-meta">${escHtml(sender)}</span>` : ''}
                <div class="msg-bubble">${escHtml(message)}</div>
                <span class="msg-time">${time}</span>`;
            container.appendChild(wrapper);
            container.scrollTop = container.scrollHeight;
        }

        async function sendMessage() {
            if (!isMember) return;
            const input = document.getElementById("messageInput");
            const msg = input.value.trim();
            if (!msg) return;
            input.value = '';
            try {
                await connection.invoke("SendMessage", communityId, msg);
            } catch {
                showToast("Failed to send message.");
            }
        }

        function handleKey(e) {
            if (e.key === 'Enter' && !e.shiftKey) { e.preventDefault(); sendMessage(); }
        }

        async function typing() {
            if (!isMember || connection.state !== signalR.HubConnectionState.Connected) return;
            try { await connection.invoke("Typing", communityId); } catch { /* silent */ }
        }

        async function joinCommunity() {
            const loggedIn = '@User.Identity.IsAuthenticated'.toLowerCase() === 'true';
            if (!loggedIn) {
                window.location.href = '/Identity/Account/Login';
                return;
            }

            const token = document.querySelector('meta[name="csrf-token"]')?.content;
            try {
                const res = await fetch(`/api/CommunityChat/JoinCommunity?communityId=${communityId}`, {
                    method: "POST",
                    headers: { "RequestVerificationToken": token ?? '' }
                });

                if (!res.ok) { showToast("Failed to join. You may already be a member."); return; }

                isMember = true;
                document.getElementById("joinBtn")?.remove();
                document.getElementById("guestBanner")?.remove();

                const chatBox = document.getElementById("chatBox");
                const inputRow = document.createElement("div");
                inputRow.id = "inputRow";
                inputRow.innerHTML = `
                    <input type="text" id="messageInput" placeholder="Write a message…"
                           onkeydown="handleKey(event)" oninput="typing()" />
                    <button id="sendBtn" onclick="sendMessage()" title="Send">
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none"
                             stroke="currentColor" stroke-width="2.2"
                             stroke-linecap="round" stroke-linejoin="round">
                            <line x1="22" y1="2" x2="11" y2="13"/>
                            <polygon points="22 2 15 22 11 13 2 9 22 2"/>
                        </svg>
                    </button>`;

                const indicator = document.getElementById("typingIndicator");
                chatBox.insertBefore(inputRow, indicator);

                await connection.invoke("JoinCommunity", communityId);
                loadMessages();
            } catch {
                showToast("An error occurred. Please try again.");
            }
        }

        function showToast(msg) {
            const t = document.getElementById("toast");
            t.textContent = msg;
            t.classList.add("show");
            setTimeout(() => t.classList.remove("show"), 3500);
        }

        function escHtml(s) {
            return String(s)
                .replace(/&/g, "&amp;")
                .replace(/</g, "&lt;")
                .replace(/>/g, "&gt;")
                .replace(/"/g, "&quot;");
        }
    </script>
</body>
</html>