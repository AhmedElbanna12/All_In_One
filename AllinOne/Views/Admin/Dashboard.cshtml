@{
    ViewData["Title"] = "Dashboard";
}

<h2>@ViewData["Title"]</h2>

<p>مرحبًا بك في لوحة تحكم الأدمن. من هنا يمكنك إدارة المنح الدراسية بسهولة.</p>

<div class="row mt-4">
    <!-- إدارة المنح -->
    <div class="col-md-3 mb-3">
        <div class="card text-center">
            <div class="card-body">
                <h5 class="card-title">قائمة المنح</h5>
                <p class="card-text">عرض جميع المنح المتوفرة على المنصة</p>
                <a asp-controller="Scholarships" asp-action="Index" class="btn btn-primary">اذهب إلى القائمة</a>
            </div>
        </div>
    </div>

    <div class="col-md-3 mb-3">
        <div class="card text-center">
            <div class="card-body">
                <h5 class="card-title">إنشاء منحة جديدة</h5>
                <p class="card-text">أضف منحة جديدة للمنصة بسهولة</p>
                <a asp-controller="Scholarships" asp-action="Create" class="btn btn-success">إنشاء منحة</a>
            </div>
        </div>
    </div>

    <!-- تعديل المنح (يمكنك ربطه مع Index لاحقًا لاختيار المنحة) -->
    <div class="col-md-3 mb-3">
        <div class="card text-center">
            <div class="card-body">
                <h5 class="card-title">تعديل منحة</h5>
                <p class="card-text">اختر منحة للتعديل من القائمة</p>
                <a asp-controller="Scholarships" asp-action="Index" class="btn btn-warning">تعديل منحة</a>
            </div>
        </div>
    </div>

    <!-- حذف المنح -->
    <div class="col-md-3 mb-3">
        <div class="card text-center">
            <div class="card-body">
                <h5 class="card-title">حذف منحة</h5>
                <p class="card-text">اختر منحة للحذف من القائمة</p>
                <a asp-controller="Scholarships" asp-action="Index" class="btn btn-danger">حذف منحة</a>
            </div>
        </div>
    </div>
</div>